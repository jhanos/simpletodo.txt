<?xml version="1.0" encoding="utf-8"?>
<!-- Row for a task item in the ListView -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:minHeight="48dp">

    <!-- Completion checkbox (decorative state indicator, tap handled by row) -->
    <CheckBox
        android:id="@+id/completedCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:focusable="false"
        android:clickable="false" />

    <!-- Priority badge (e.g. "A") - hidden when NONE -->
    <TextView
        android:id="@+id/priorityBadge"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/bg_priority"
        android:visibility="gone" />

    <!-- Spacer between badge and text -->
    <Space
        android:id="@+id/badgeSpacer"
        android:layout_width="8dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/taskText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@android:color/primary_text_light" />

        <!-- Colored context (@) and project (+) tag pills -->
        <LinearLayout
            android:id="@+id/tagsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/metaRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="2dp">

            <TextView
                android:id="@+id/dueDateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@android:color/darker_gray"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Edit button -->
    <TextView
        android:id="@+id/editButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="✎"
        android:textSize="18sp"
        android:textColor="@android:color/darker_gray"
        android:clickable="true"
        android:focusable="false" />

</LinearLayout>
